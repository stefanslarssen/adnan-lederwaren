<!-- Owl Carousel SAFE INIT -->
<script>
jQuery(window).on('load', function(){

    var owl = jQuery('.owl-carousel');

    owl.owlCarousel({
        loop: true,
        margin: 10,
        nav: true,
        dots: true,
        items: 1,
        responsive:{
            0:{ items:1 },
            600:{ items:1 },
            1000:{ items:1 }
        }
    });

    setTimeout(function(){
        owl.trigger('refresh.owl.carousel');
    }, 500);

});
</script>

<!-- Back to top -->
<script>
jq(document).ready(function(){

    var toggleHeight = jq(window).outerHeight() * 2;

    jq(window).scroll(function() {
        if (jq(window).scrollTop() > toggleHeight) {
            jq(".m-backtotop").addClass("active");
        } else {
            jq(".m-backtotop").removeClass("active");
        }
    });

    jq(".m-backtotop").click(function() {
        jq("html, body").animate({
            scrollTop: 0,
        }, "slow");
        return false;
    });

});
</script>

<!-- GLightbox -->
<script>
var lightbox = GLightbox({
    loop: true
});
</script>

<!-- Fix Email Subscribe Label -->
<script>
jq(document).ready(function(){

    jq('.es-field-wrap').each(function() {

        const $label = jq(this).find('label.es-field-label');
        const labelText = $label.contents().filter(function() {
            return this.nodeType === 3;
        }).text().trim();

        const $input = $label.find('input');

        const $newLabel = jq('<label>', {
            class: 'es-field-label',
            text: labelText
        });

        $label.replaceWith($newLabel);
        $newLabel.after($input);

    });

});
</script>

<!-- Swiper -->
<script>
var swiperThumbs = new Swiper(".mySwiper", {
    loop: true,
    spaceBetween: 10,
    slidesPerView: 4,
    freeMode: true,
    watchSlidesProgress: true,
});

var swiperMain = new Swiper(".mySwiper2", {
    loop: true,
    spaceBetween: 10,
    navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
    },
    thumbs: {
        swiper: swiperThumbs,
    },
});
</script>

